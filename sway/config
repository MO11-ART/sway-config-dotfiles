### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term footclient
set $browser flatpak run app.zen_browser.zen

font pango:Iosevka Term 6

### Output configuration
output eDP-1 mode 1920x1080 scale 1.25
#output * bg /home/hasher/Downloads/patrick-fore-Ikq7yAlvfGs-unsplash.jpg fill
output * allow_tearing yes
output * max_render_time off

